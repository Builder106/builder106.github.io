{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2"],
        "maxWaitForFcp": 60000,
        "maxWaitForLoad": 90000,
        "networkQuietThresholdMs": 8000,
        "cpuQuietThresholdMs": 8000,
        "chromeFlags": "--enable-unsafe-swiftshader --use-gl=angle --use-angle=swiftshader --ignore-gpu-blocklist"
      }
    },
    "assert": {
      "assertions": {
        "_comment": "All warn-only on desktop. The GitHub Actions runner has no GPU, so Lighthouse uses SwiftShader for WebGL — software-rasterising the 3D scene blocks the main thread for ~5 s during boot and drags TBT + Speed Index to zero. That's a CI-runner artifact, not a real-user signal (real desktop users have GPUs and don't hit this). Mobile Lighthouse is where we gate; desktop is run for the report + LCP / FCP / a11y / SEO signals which *are* useful even on software-WebGL.",
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": "off",
        "speed-index": "off",
        "first-contentful-paint": ["warn", { "maxNumericValue": 1800 }],
        "uses-responsive-images": "off",
        "unused-javascript": "off",
        "uses-rel-preconnect": "off",
        "target-size": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
